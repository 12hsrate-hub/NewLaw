# Для реального auth flow замени placeholder-значения на реальные данные проекта Supabase.
# С этими примерами UI откроется, но регистрация, подтверждение email и вход работать не будут.
# APP_URL нужен для server-side security redirect URL и будущих recovery/email-change сценариев.
# SUPABASE_SERVICE_ROLE_KEY нужен для service-role helper и server-side admin security actions.
# SMTP для auth-писем настраивается не в приложении, а вручную в Supabase Dashboard -> Authentication -> Email -> SMTP Settings.
# Официально подтверждённый SMTP-порт Mail.ru из справки: 465 с SSL/TLS. Порт должен оставаться конфигурируемым.
# Альтернативный порт 2525 можно проверять отдельно, но не считать официальным дефолтом.
# SMTP user/sender для production-контура: lawyer5rp@inbox.ru. Использовать пароль внешнего приложения, а не обычный пароль почты.
# SMTP-секреты не хранить в git, .env examples, README или тестах.
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lawyer5rp_local
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/lawyer5rp_local

# DIRECT_URL должен быть задан явно даже в local.
# Для local допускается тот же URL, что и DATABASE_URL.

NEXT_PUBLIC_SUPABASE_URL=https://your-local-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
FORUM_SESSION_ENCRYPTION_KEY=your-local-forum-session-encryption-key-at-least-32-characters
OGP_FORUM_THREAD_FORM_URL=https://forum.gta5rp.com/forums/your-ogp-section.123/post-thread

# Все AI-вызовы server legal assistant идут только через proxy-layer.
# Прямой вызов OpenAI из assistant-кода запрещён.
# Секреты не кладутся в AI_PROXY_CONFIGS_JSON: JSON хранит только metadata proxy entry.
AI_PROXY_ACTIVE_KEY=primary
AI_PROXY_CONFIGS_JSON=[{"proxyKey":"primary","providerKey":"openai_compatible","endpointUrl":"http://127.0.0.1:3000/api/assistant-proxy","secretEnvKeyName":"AI_PROXY_INTERNAL_TOKEN","model":"gpt-5.4","priority":100,"weight":1,"isEnabled":true,"capabilities":["server_legal_assistant"]}]
AI_PROXY_INTERNAL_TOKEN=your-local-internal-proxy-token

# OPENAI_API_KEY остаётся только на серверной стороне и используется internal proxy route.
OPENAI_API_KEY=your-local-openai-key
