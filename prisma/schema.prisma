generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CharacterRoleKey {
  citizen
  lawyer
}

enum CharacterAccessFlagKey {
  advocate
  server_editor
  server_admin
  tester
}

enum AccountSecurityReason {
  admin_reset
  security_policy
}

enum AuditActionKey {
  forgot_password_requested
  password_reset_completed
  password_changed_self
  password_reset_admin_temp
  email_change_requested_self
  email_change_completed
  email_changed_admin
  recovery_email_sent_admin
  forum_connection_saved
  forum_connection_validated
  forum_connection_disabled
}

enum AuditLogStatus {
  success
  failure
}

enum LawKind {
  primary
  supplement
}

enum LawVersionStatus {
  imported_draft
  current
  superseded
}

enum LawImportRunStatus {
  running
  success
  failure
}

enum PrecedentSourceTopicDiscoveryStatus {
  running
  success
  failure
}

enum LawImportRunMode {
  discovery
  import_law
}

enum LawBlockType {
  section
  chapter
  article
  appendix
  unstructured
}

enum PrecedentSourceTopicClassification {
  precedent
  ignored
}

enum PrecedentVersionStatus {
  imported_draft
  current
  superseded
}

enum PrecedentValidityStatus {
  applicable
  limited
  obsolete
}

enum PrecedentBlockType {
  facts
  issue
  holding
  reasoning
  resolution
  unstructured
}

enum PrecedentImportRunStatus {
  running
  success
  failure
}

enum PrecedentImportRunMode {
  discovery
  import_source_topic
}

enum DocumentType {
  ogp_complaint
  rehabilitation
  lawsuit
  attorney_request
}

enum DocumentStatus {
  draft
  generated
  published
}

enum ForumConnectionState {
  connected_unvalidated
  valid
  invalid
  disabled
}

enum OgpForumSyncState {
  not_published
  current
  outdated
  failed
  manual_untracked
}

enum OgpForumPublicationOperation {
  publish_create
  publish_update
}

enum OgpForumPublicationAttemptStatus {
  started
  succeeded
  failed
}

enum AIRequestStatus {
  success
  failure
  unavailable
}

enum AssistantGuestAnswerStatus {
  answered
  no_norms
}

model Account {
  id                      String                 @id @db.Uuid
  email                   String                 @unique
  login                   String                 @unique
  pendingEmail            String?
  pendingEmailRequestedAt DateTime?
  mustChangePassword      Boolean                @default(false)
  mustChangePasswordReason AccountSecurityReason?
  passwordChangedAt       DateTime?
  isSuperAdmin            Boolean                @default(false)
  characters              Character[]
  userServerState         UserServerState[]
  confirmedLawVersions    LawVersion[]           @relation("LawVersionConfirmer")
  confirmedPrecedentVersions PrecedentVersion[]  @relation("PrecedentVersionConfirmer")
  actorAuditLogs          AuditLog[]             @relation("AuditActor")
  targetAuditLogs         AuditLog[]             @relation("AuditTarget")
  aiRequests              AIRequest[]
  documents               Document[]
  trustors                Trustor[]
  forumSessionConnections ForumSessionConnection[]
  ogpForumPublicationAttempts OgpForumPublicationAttempt[]
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
}

model Server {
  id              String            @id @default(cuid())
  code            String            @unique
  name            String
  isActive        Boolean           @default(true)
  sortOrder       Int               @default(0)
  characters      Character[]
  userServerState UserServerState[]
  lawSourceIndexes LawSourceIndex[]
  laws            Law[]
  lawImportRuns   LawImportRun[]
  precedentSourceTopics PrecedentSourceTopic[]
  precedents      Precedent[]
  precedentImportRuns PrecedentImportRun[]
  assistantGuestSessions AssistantGuestSession[]
  aiRequests      AIRequest[]
  documents       Document[]
  trustors        Trustor[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model UserServerState {
  id                String     @id @default(cuid())
  accountId         String     @db.Uuid
  serverId          String
  activeCharacterId String?
  lastSelectedAt    DateTime?
  account           Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  server            Server     @relation(fields: [serverId], references: [id], onDelete: Cascade)
  activeCharacter   Character? @relation("ActiveCharacter", fields: [activeCharacterId], references: [id], onDelete: SetNull)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@unique([accountId, serverId])
  @@index([serverId])
}

model Character {
  id                String                @id @default(cuid())
  accountId         String                @db.Uuid
  serverId          String
  activeSignatureId String?               @unique
  fullName          String
  nickname          String
  passportNumber    String
  isProfileComplete Boolean               @default(false)
  profileDataJson   Json?
  deletedAt         DateTime?
  account           Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  server            Server                @relation(fields: [serverId], references: [id], onDelete: Cascade)
  activeSignature   CharacterSignature?   @relation("ActiveCharacterSignature", fields: [activeSignatureId], references: [id], onDelete: SetNull)
  roles             CharacterRole[]
  accessFlags       CharacterAccessFlag[]
  activeInStates    UserServerState[]     @relation("ActiveCharacter")
  signatures        CharacterSignature[]  @relation("CharacterSignatureHistory")
  documents         Document[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([accountId, serverId, deletedAt])
  @@index([accountId, serverId, passportNumber])
}

model CharacterSignature {
  id               String      @id
  characterId      String
  storagePath      String      @unique
  mimeType         String
  width            Int
  height           Int
  fileSize         Int
  isActive         Boolean     @default(false)
  character        Character   @relation("CharacterSignatureHistory", fields: [characterId], references: [id], onDelete: Restrict)
  activeForCharacter Character? @relation("ActiveCharacterSignature")
  createdAt        DateTime    @default(now())

  @@index([characterId, createdAt])
  @@index([characterId, isActive, createdAt])
}

model Trustor {
  id             String    @id @default(cuid())
  accountId      String    @db.Uuid
  serverId       String
  fullName       String
  passportNumber String
  phone          String?
  icEmail        String?
  passportImageUrl String?
  note           String?
  deletedAt      DateTime?
  account        Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  server         Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  documents      Document[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([accountId, createdAt])
  @@index([accountId, serverId, deletedAt])
  @@index([serverId, deletedAt])
}

model CharacterRole {
  id         String           @id @default(cuid())
  characterId String
  roleKey    CharacterRoleKey
  character  Character        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())

  @@unique([characterId, roleKey])
}

model CharacterAccessFlag {
  id          String                   @id @default(cuid())
  characterId String
  flagKey     CharacterAccessFlagKey
  character   Character                @relation(fields: [characterId], references: [id], onDelete: Cascade)
  createdAt   DateTime                 @default(now())

  @@unique([characterId, flagKey])
}

model AuditLog {
  id              String         @id @default(cuid())
  actionKey       AuditActionKey
  status          AuditLogStatus
  actorAccountId  String?        @db.Uuid
  targetAccountId String?        @db.Uuid
  comment         String?
  metadataJson    Json?
  ipAddress       String?
  userAgent       String?
  actorAccount    Account?       @relation("AuditActor", fields: [actorAccountId], references: [id], onDelete: SetNull)
  targetAccount   Account?       @relation("AuditTarget", fields: [targetAccountId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())

  @@index([actionKey, createdAt])
  @@index([actorAccountId, createdAt])
  @@index([targetAccountId, createdAt])
}

model Document {
  id                         String         @id @default(cuid())
  accountId                  String         @db.Uuid
  serverId                   String
  characterId                String
  trustorId                  String?
  documentType               DocumentType
  title                      String
  status                     DocumentStatus @default(draft)
  formSchemaVersion          String
  snapshotCapturedAt         DateTime
  authorSnapshotJson         Json
  signatureSnapshotJson      Json?
  formPayloadJson            Json?
  generatedArtifactJson      Json?
  generatedArtifactText      String?
  generatedOutputFormat      String?
  generatedRendererVersion   String?
  lastGeneratedBbcode        String?
  generatedAt                DateTime?
  generatedLawVersion        String?
  generatedTemplateVersion   String?
  generatedFormSchemaVersion String?
  publicationUrl             String?
  isSiteForumSynced          Boolean        @default(false)
  forumSyncState             OgpForumSyncState @default(not_published)
  forumThreadId              String?
  forumPostId                String?
  forumPublishedBbcodeHash   String?
  forumLastPublishedAt       DateTime?
  forumLastSyncError         String?
  isModifiedAfterGeneration  Boolean        @default(false)
  deletedAt                  DateTime?
  account                    Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  server                     Server         @relation(fields: [serverId], references: [id], onDelete: Restrict)
  character                  Character      @relation(fields: [characterId], references: [id], onDelete: Restrict)
  trustor                    Trustor?       @relation(fields: [trustorId], references: [id], onDelete: Restrict)
  ogpForumPublicationAttempts OgpForumPublicationAttempt[]
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  @@index([accountId, createdAt])
  @@index([accountId, serverId, documentType, createdAt])
  @@index([accountId, trustorId, documentType, createdAt])
  @@index([serverId, documentType, status, createdAt])
  @@index([documentType, forumSyncState, createdAt])
}

model ForumSessionConnection {
  id                      String               @id @default(cuid())
  accountId               String               @db.Uuid
  providerKey             String
  state                   ForumConnectionState
  encryptedSessionPayload String?
  forumUserId             String?
  forumUsername           String?
  validatedAt             DateTime?
  lastValidationError     String?
  disabledAt              DateTime?
  account                 Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@unique([accountId, providerKey])
  @@index([providerKey, state])
}

model OgpForumPublicationAttempt {
  id           String                           @id @default(cuid())
  documentId   String
  accountId    String                           @db.Uuid
  operation    OgpForumPublicationOperation
  status       OgpForumPublicationAttemptStatus
  forumThreadId String?
  forumPostId  String?
  errorCode    String?
  errorSummary String?
  document     Document                         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  account      Account                          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt    DateTime                         @default(now())
  updatedAt    DateTime                         @updatedAt

  @@index([documentId, createdAt])
  @@index([accountId, createdAt])
  @@index([operation, status, createdAt])
}

model LawSourceIndex {
  id                  String             @id @default(cuid())
  serverId            String
  indexUrl            String
  isEnabled           Boolean            @default(true)
  lastDiscoveredAt    DateTime?
  lastDiscoveryStatus LawImportRunStatus?
  lastDiscoveryError  String?
  server              Server             @relation(fields: [serverId], references: [id], onDelete: Cascade)
  importRuns          LawImportRun[]
  precedentSourceTopics PrecedentSourceTopic[]
  precedentImportRuns PrecedentImportRun[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([serverId, indexUrl])
  @@index([serverId, isEnabled])
}

model Law {
  id                     String       @id @default(cuid())
  serverId               String
  lawKey                 String
  title                  String
  topicUrl               String
  topicExternalId        String
  lawKind                LawKind
  relatedPrimaryLawId    String?
  currentVersionId       String?      @unique
  isExcluded             Boolean      @default(false)
  classificationOverride LawKind?
  internalNote           String?
  server                 Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  relatedPrimaryLaw      Law?         @relation("LawSupplementRelation", fields: [relatedPrimaryLawId], references: [id], onDelete: SetNull)
  supplements            Law[]        @relation("LawSupplementRelation")
  currentVersion         LawVersion?  @relation("CurrentLawVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions               LawVersion[] @relation("LawVersions")
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@unique([serverId, lawKey])
  @@unique([serverId, topicExternalId])
  @@index([serverId, lawKind, isExcluded])
}

model LawVersion {
  id                 String           @id @default(cuid())
  lawId              String
  status             LawVersionStatus @default(imported_draft)
  normalizedFullText String
  sourceSnapshotHash String
  normalizedTextHash String
  importedAt         DateTime         @default(now())
  confirmedAt        DateTime?
  confirmedByAccountId String?        @db.Uuid
  law                Law              @relation("LawVersions", fields: [lawId], references: [id], onDelete: Cascade)
  confirmedByAccount Account?         @relation("LawVersionConfirmer", fields: [confirmedByAccountId], references: [id], onDelete: SetNull)
  currentForLaw      Law?             @relation("CurrentLawVersion")
  sourcePosts        LawSourcePost[]
  blocks             LawBlock[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([lawId, normalizedTextHash])
  @@index([lawId, status, importedAt])
}

model LawSourcePost {
  id                     String     @id @default(cuid())
  lawVersionId           String
  postExternalId         String
  postUrl                String
  postOrder              Int
  authorName             String?
  postedAt               DateTime?
  rawHtml                String
  rawText                String
  normalizedTextFragment String
  lawVersion             LawVersion @relation(fields: [lawVersionId], references: [id], onDelete: Cascade)
  createdAt              DateTime   @default(now())

  @@unique([lawVersionId, postExternalId])
  @@unique([lawVersionId, postOrder])
}

model LawBlock {
  id                      String       @id @default(cuid())
  lawVersionId            String
  blockType               LawBlockType
  blockOrder              Int
  blockTitle              String?
  blockText               String
  parentBlockId           String?
  articleNumberNormalized String?
  lawVersion              LawVersion   @relation(fields: [lawVersionId], references: [id], onDelete: Cascade)
  parentBlock             LawBlock?    @relation("LawBlockTree", fields: [parentBlockId], references: [id], onDelete: SetNull)
  childBlocks             LawBlock[]   @relation("LawBlockTree")
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  @@unique([lawVersionId, blockOrder])
  @@index([lawVersionId, blockType, blockOrder])
  @@index([lawVersionId, articleNumberNormalized])
}

model LawImportRun {
  id            String             @id @default(cuid())
  serverId      String
  sourceIndexId String?
  mode          LawImportRunMode
  status        LawImportRunStatus
  lockKey       String?            @unique
  startedAt     DateTime           @default(now())
  finishedAt    DateTime?
  summary       String?
  error         String?
  server        Server             @relation(fields: [serverId], references: [id], onDelete: Cascade)
  sourceIndex   LawSourceIndex?    @relation(fields: [sourceIndexId], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([serverId, status, startedAt])
  @@index([sourceIndexId, status, startedAt])
}

model PrecedentSourceTopic {
  id                    String                               @id @default(cuid())
  serverId              String
  sourceIndexId         String
  topicUrl              String
  topicExternalId       String
  title                 String
  isExcluded            Boolean                              @default(false)
  classificationOverride PrecedentSourceTopicClassification?
  internalNote          String?
  lastDiscoveredAt      DateTime?
  lastDiscoveryStatus   PrecedentSourceTopicDiscoveryStatus?
  lastDiscoveryError    String?
  server                Server                               @relation(fields: [serverId], references: [id], onDelete: Cascade)
  sourceIndex           LawSourceIndex                       @relation(fields: [sourceIndexId], references: [id], onDelete: Cascade)
  precedents            Precedent[]
  importRuns            PrecedentImportRun[]
  createdAt             DateTime                             @default(now())
  updatedAt             DateTime                             @updatedAt

  @@unique([serverId, topicExternalId])
  @@index([serverId, isExcluded])
  @@index([sourceIndexId, createdAt])
}

model Precedent {
  id                     String                  @id @default(cuid())
  serverId               String
  precedentSourceTopicId String
  precedentKey           String
  displayTitle           String
  precedentLocatorKey    String
  currentVersionId       String?                 @unique
  validityStatus         PrecedentValidityStatus @default(applicable)
  server                 Server                  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  sourceTopic            PrecedentSourceTopic    @relation(fields: [precedentSourceTopicId], references: [id], onDelete: Cascade)
  currentVersion         PrecedentVersion?       @relation("CurrentPrecedentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions               PrecedentVersion[]      @relation("PrecedentVersions")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@unique([serverId, precedentKey])
  @@unique([precedentSourceTopicId, precedentLocatorKey])
  @@index([serverId, validityStatus])
}

model PrecedentVersion {
  id                 String                  @id @default(cuid())
  precedentId        String
  status             PrecedentVersionStatus  @default(imported_draft)
  normalizedFullText String
  sourceSnapshotHash String
  normalizedTextHash String
  importedAt         DateTime                @default(now())
  confirmedAt        DateTime?
  confirmedByAccountId String?               @db.Uuid
  precedent          Precedent               @relation("PrecedentVersions", fields: [precedentId], references: [id], onDelete: Cascade)
  confirmedByAccount Account?                @relation("PrecedentVersionConfirmer", fields: [confirmedByAccountId], references: [id], onDelete: SetNull)
  currentForPrecedent Precedent?             @relation("CurrentPrecedentVersion")
  sourcePosts        PrecedentSourcePost[]
  blocks             PrecedentBlock[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@unique([precedentId, normalizedTextHash])
  @@index([precedentId, status, importedAt])
}

model PrecedentSourcePost {
  id                     String           @id @default(cuid())
  precedentVersionId     String
  postExternalId         String
  postUrl                String
  postOrder              Int
  authorName             String?
  postedAt               DateTime?
  rawHtml                String
  rawText                String
  normalizedTextFragment String
  precedentVersion       PrecedentVersion @relation(fields: [precedentVersionId], references: [id], onDelete: Cascade)
  createdAt              DateTime         @default(now())

  @@unique([precedentVersionId, postExternalId])
  @@unique([precedentVersionId, postOrder])
}

model PrecedentBlock {
  id                 String             @id @default(cuid())
  precedentVersionId String
  blockType          PrecedentBlockType
  blockOrder         Int
  blockTitle         String?
  blockText          String
  parentBlockId      String?
  precedentVersion   PrecedentVersion   @relation(fields: [precedentVersionId], references: [id], onDelete: Cascade)
  parentBlock        PrecedentBlock?    @relation("PrecedentBlockTree", fields: [parentBlockId], references: [id], onDelete: SetNull)
  childBlocks        PrecedentBlock[]   @relation("PrecedentBlockTree")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([precedentVersionId, blockOrder])
  @@index([precedentVersionId, blockType, blockOrder])
}

model PrecedentImportRun {
  id            String                  @id @default(cuid())
  serverId      String
  sourceIndexId String?
  sourceTopicId String?
  mode          PrecedentImportRunMode
  status        PrecedentImportRunStatus
  lockKey       String?                 @unique
  startedAt     DateTime                @default(now())
  finishedAt    DateTime?
  summary       String?
  error         String?
  server        Server                  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  sourceIndex   LawSourceIndex?         @relation(fields: [sourceIndexId], references: [id], onDelete: SetNull)
  sourceTopic   PrecedentSourceTopic?   @relation(fields: [sourceTopicId], references: [id], onDelete: SetNull)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([serverId, status, startedAt])
  @@index([sourceIndexId, status, startedAt])
  @@index([sourceTopicId, status, startedAt])
}

model AssistantGuestSession {
  id                String                     @id @default(cuid())
  guestToken        String                     @unique
  ipHash            String
  userAgentHash     String
  usedFreeQuestionAt DateTime?
  lastServerId      String?
  questionText      String?
  answerMarkdown    String?
  answerMetadataJson Json?
  answerStatus      AssistantGuestAnswerStatus?
  lastAnsweredAt    DateTime?
  lastServer        Server?                    @relation(fields: [lastServerId], references: [id], onDelete: SetNull)
  aiRequests        AIRequest[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([ipHash, userAgentHash, usedFreeQuestionAt])
  @@index([lastServerId, usedFreeQuestionAt])
}

model AIRequest {
  id                  String          @id @default(cuid())
  accountId           String?         @db.Uuid
  serverId            String?
  guestSessionId      String?
  featureKey          String
  providerKey         String?
  proxyKey            String?
  model               String?
  requestPayloadJson  Json?
  responsePayloadJson Json?
  status              AIRequestStatus
  errorMessage        String?
  account             Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  server              Server?         @relation(fields: [serverId], references: [id], onDelete: SetNull)
  guestSession        AssistantGuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  createdAt           DateTime        @default(now())

  @@index([featureKey, createdAt])
  @@index([accountId, createdAt])
  @@index([serverId, createdAt])
  @@index([guestSessionId, createdAt])
}
